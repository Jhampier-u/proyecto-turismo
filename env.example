# =============================================
# UDAExplore - Variables de Entorno (Railway)
# =============================================
# IMPORTANTE: No subas el .env real a GitHub.
# Solo este .env.example va en el repositorio.
# Las variables reales se configuran en el
# dashboard de Railway (Settings > Variables).
# =============================================

APP_NAME=UDAExplore
APP_ENV=production
APP_KEY=                        # Railway auto-genera esto con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=                        # Railway te da esta URL al desplegar (ej: https://udaexplore.up.railway.app)

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Base de datos ──────────────────────────
# Railway inyecta estas variables automáticamente
# cuando agregas un servicio MySQL. Solo cópialas
# desde el panel de Railway > MySQL > Variables.
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}    # Variable interna de Railway
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ── Caché y Sesiones ───────────────────────
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ── Correo (opcional para demo) ────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@udaexplore.com"
MAIL_FROM_NAME="${APP_NAME}"
